<!-- Views/MainWindow.xaml -->
<Window x:Class="LibraryManagement.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryManagement.ViewModels"
        mc:Ignorable="d"
        Title="Управление библиотекой" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Библиотека книг" FontSize="24" FontWeight="Bold" Margin="5" Grid.Row="0"/>

        <!-- Панель фильтрации -->
        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="5" Grid.Row="1">
            <StackPanel>
                <TextBlock Text="Фильтры" FontWeight="Bold" Margin="0,0,0,5"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="5">
                        <TextBlock Text="Поиск по названию:"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Margin="5">
                        <TextBlock Text="Фильтр по автору:"/>
                        <ComboBox ItemsSource="{Binding Authors}" 
                                  SelectedItem="{Binding SelectedAuthorFilter}"
                                  DisplayMemberPath="FullName"
                                  Margin="0,2">
                            <ComboBox.ItemsSource>
                                <Binding>
                                    <Binding.Path>Authors</Binding.Path>
                                </Binding>
                            </ComboBox.ItemsSource>
                        </ComboBox>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2" Margin="5">
                        <TextBlock Text="Фильтр по жанру:"/>
                        <ComboBox ItemsSource="{Binding Genres}" 
                                  SelectedItem="{Binding SelectedGenreFilter}"
                                  DisplayMemberPath="Name"
                                  Margin="0,2"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- DataGrid для книг -->
        <DataGrid Grid.Row="2" 
                  ItemsSource="{Binding Books}" 
                  SelectedItem="{Binding SelectedBook}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Margin="5"
                  AlternatingRowBackground="LightGray"
                  AlternationCount="2">
            
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="200"/>
                <DataGridTextColumn Header="Автор" Binding="{Binding Author.FullName}" Width="150"/>
                <DataGridTextColumn Header="Жанр" Binding="{Binding Genre.Name}" Width="100"/>
                <DataGridTextColumn Header="Год" Binding="{Binding PublishYear}" Width="70"/>
                <DataGridTextColumn Header="ISBN" Binding="{Binding ISBN}" Width="120"/>
                <DataGridTextColumn Header="В наличии" Binding="{Binding QuantityInStock}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель кнопок -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
            <Button Content="Добавить книгу" Command="{Binding AddBookCommand}" 
                    Width="120" Height="30" Margin="5"/>
            <Button Content="Редактировать" Command="{Binding EditBookCommand}" 
                    Width="120" Height="30" Margin="5"/>
            <Button Content="Удалить" Command="{Binding DeleteBookCommand}" 
                    Width="120" Height="30" Margin="5"/>
            <Button Content="Управление авторами" Command="{Binding ManageAuthorsCommand}" 
                    Width="150" Height="30" Margin="5"/>
            <Button Content="Управление жанрами" Command="{Binding ManageGenresCommand}" 
                    Width="150" Height="30" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
