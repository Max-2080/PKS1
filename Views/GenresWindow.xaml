<!-- Views/GenresWindow.xaml -->
<Window x:Class="LibraryManagement.Views.GenresWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление жанрами" Height="400" Width="600"
        WindowStartupLocation="CenterOwner">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Жанры" FontSize="20" FontWeight="Bold" Margin="5" Grid.Row="0"/>

        <DataGrid Grid.Row="1" 
                  Name="dgGenres"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  Margin="5">
            
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" IsReadOnly="True" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="300"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
            <Button Content="Добавить" Click="BtnAdd_Click" Width="100" Height="30" Margin="5"/>
            <Button Content="Сохранить" Click="BtnSave_Click" Width="100" Height="30" Margin="5"/>
            <Button Content="Удалить" Click="BtnDelete_Click" Width="100" Height="30" Margin="5"/>
            <Button Content="Закрыть" Click="BtnClose_Click" Width="100" Height="30" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
