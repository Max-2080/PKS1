<!-- Views/BookWindow.xaml -->
<Window x:Class="LibraryManagement.Views.BookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Книга" Height="400" Width="500"
        WindowStartupLocation="CenterOwner">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" Margin="5"/>
        <TextBox Grid.Row="0" Grid.Column="1" Name="txtTitle" Margin="5"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Автор:" Margin="5"/>
        <ComboBox Grid.Row="1" Grid.Column="1" Name="cmbAuthor" 
                  DisplayMemberPath="FullName" Margin="5"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Жанр:" Margin="5"/>
        <ComboBox Grid.Row="2" Grid.Column="1" Name="cmbGenre" 
                  DisplayMemberPath="Name" Margin="5"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Год издания:" Margin="5"/>
        <TextBox Grid.Row="3" Grid.Column="1" Name="txtYear" Margin="5"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="ISBN:" Margin="5"/>
        <TextBox Grid.Row="4" Grid.Column="1" Name="txtISBN" Margin="5"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Количество:" Margin="5"/>
        <TextBox Grid.Row="5" Grid.Column="1" Name="txtQuantity" Margin="5"/>

        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="10">
            <Button Content="Сохранить" Click="BtnSave_Click" Width="100" Height="30" Margin="5"/>
            <Button Content="Отмена" Click="BtnCancel_Click" Width="100" Height="30" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
